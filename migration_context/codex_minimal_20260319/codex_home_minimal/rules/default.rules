prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "matlab -batch \"addpath('src'); cfg=HCDR_config_planar('n_m',6); vm=make_mycobot280_visual_model(); q0=[0;0;0;cfg.q_home]; N=30; offs=zeros(3,N); flgErr=zeros(3,N); for i=1:N; q=q0; q(4:9)=q(4:9)+0.5*(rand(6,1)-0.5); kin0=HCDR_kinematics_planar(q,cfg); cfg0=cfg; cfg0.arm.tool_offset_in_ee=[0;0;0]; kinFlange=HCDR_kinematics_planar(q,cfg0); pTip=vm.tip_world_fn(q,cfg); pFlangeU=vm.flange_world_fn(q,cfg); R=kinFlange.T_0e(1:3,1:3); offs(:,i)=R'*(pTip-kinFlange.p_ee); flgErr(:,i)=pFlangeU-kinFlange.p_ee; end; mOff=mean(offs,2); sOff=std(offs,0,2); mFl=mean(flgErr,2); sFl=std(flgErr,0,2); fprintf('offset_mean=[%.5f %.5f %.5f]\\n',mOff); fprintf('offset_std=[%.5f %.5f %.5f]\\n',sOff); fprintf('flange_err_mean=[%.5f %.5f %.5f]\\n',mFl); fprintf('flange_err_std=[%.5f %.5f %.5f]\\n',sFl);\""], decision="allow")
